default_platform(:ios)

platform :ios do
  desc "Build GlucoDash en upload naar TestFlight"
  lane :build_upload do

    # Key wordt via key_filepath geladen (schrijf stap in workflow)
    api_key = app_store_connect_api_key(
      key_id: ENV['FASTLANE_KEY_ID'],
      issuer_id: ENV['FASTLANE_ISSUER_ID'],
      key_filepath: "api_key.p8"
    )

    update_code_signing_settings(
      use_automatic_signing: true,
      team_id: ENV["TEAMID"],
      path: "ios/App/App.xcodeproj"
    )

    update_app_identifier(
      xcodeproj: "ios/App/App.xcodeproj",
      plist_path: "App/Info.plist",
      app_identifier: "com.9CGZ7BWVXT.glucodash"
    )

    # Gebruik API key voor xcodebuild authenticatie (automatisch provisioning)
    api_key_path = File.expand_path("api_key_pkcs8.p8")
    # Fallback: als pkcs8 niet bestaat, gebruik de geconverteerde key
    api_key_path = File.expand_path("api_key.p8") unless File.exist?(api_key_path)

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates -authenticationKeyPath #{api_key_path} -authenticationKeyID #{ENV['FASTLANE_KEY_ID']} -authenticationKeyIssuerID #{ENV['FASTLANE_ISSUER_ID']}",
      export_options: {
        provisioningProfiles: {},
        signingStyle: "automatic"
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
