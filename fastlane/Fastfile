require 'base64'

default_platform(:ios)

platform :ios do
  desc "Build GlucoDash en upload naar TestFlight"
  lane :build_upload do

    # API key voor App Store Connect (upload + profile download)
    api_key = app_store_connect_api_key(
      key_id: ENV['FASTLANE_KEY_ID'],
      issuer_id: ENV['FASTLANE_ISSUER_ID'],
      key_filepath: "api_key.p8"
    )

    # Maak tijdelijke keychain aan voor CI
    create_keychain(
      name: "build.keychain",
      password: "buildpass",
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    # Importeer distribution certificate uit secret (P12 base64)
    cert_path = "/tmp/dist_cert.p12"
    File.write(cert_path, Base64.decode64(ENV['CERT_P12']))
    import_certificate(
      certificate_path: cert_path,
      certificate_password: ENV['CERT_PASSWORD'],
      keychain_name: "build.keychain",
      keychain_password: "buildpass"
    )

    # Download provisioning profile
    profile = sigh(
      api_key: api_key,
      app_identifier: "com.#{ENV['TEAMID']}.glucodash",
      output_path: "/tmp/profiles",
      provisioning_name: "GlucoDash AppStore",
      force: true,
      readonly: false
    )

    # Manual signing met het gedownloade profiel
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["TEAMID"],
      path: "ios/App/App.xcodeproj",
      profile_name: "GlucoDash AppStore",
      code_sign_identity: "iPhone Distribution"
    )

    update_app_identifier(
      xcodeproj: "ios/App/App.xcodeproj",
      plist_path: "App/Info.plist",
      app_identifier: "com.#{ENV['TEAMID']}.glucodash"
    )

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.#{ENV['TEAMID']}.glucodash" => "GlucoDash AppStore"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
