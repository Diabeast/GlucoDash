default_platform(:ios)

platform :ios do
  desc "Build GlucoDash en upload naar TestFlight"
  lane :build_upload do

    # API key voor App Store Connect
    # key_filepath is absoluut pad vanuit project root (api_key.p8 staat naast fastlane/)
    api_key = app_store_connect_api_key(
      key_id: ENV['FASTLANE_KEY_ID'],
      issuer_id: ENV['FASTLANE_ISSUER_ID'],
      key_filepath: File.expand_path("../api_key.p8", __dir__)
    )

    # Maak tijdelijke keychain aan voor CI
    create_keychain(
      name: "build.keychain",
      password: "buildpass",
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    # Haal Distribution Certificate op via API (of maak nieuw aan als er geen is)
    # Geen P12/Mac nodig: cert genereert een nieuw keypair op CI indien nodig
    cert(
      api_key: api_key,
      keychain_name: "build.keychain",
      keychain_password: "buildpass"
    )

    # Zorg dat codesign de private key kan gebruiken zonder UI-prompt (CI vereiste)
    sh("security set-key-partition-list -S apple-tool:,apple: -s -k buildpass ~/Library/Keychains/build.keychain-db 2>/dev/null || true")

    # Download/maak provisioning profile aan (force=true zodat het nieuwe cert erin zit)
    sigh(
      api_key: api_key,
      app_identifier: "com.#{ENV['TEAMID']}.glucodash",
      provisioning_name: "GlucoDash AppStore",
      force: true
    )

    # Manual signing met het gedownloade profiel
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["TEAMID"],
      path: "ios/App/App.xcodeproj",
      profile_name: "GlucoDash AppStore",
      code_sign_identity: "iPhone Distribution"
    )

    update_app_identifier(
      xcodeproj: "ios/App/App.xcodeproj",
      plist_path: "App/Info.plist",
      app_identifier: "com.#{ENV['TEAMID']}.glucodash"
    )

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.#{ENV['TEAMID']}.glucodash" => "GlucoDash AppStore"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
