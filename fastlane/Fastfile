default_platform(:ios)

platform :ios do
  desc "Build GlucoDash en upload naar TestFlight"
  lane :build_upload do

    # API key voor App Store Connect
    api_key = app_store_connect_api_key(
      key_id: ENV['FASTLANE_KEY_ID'],
      issuer_id: ENV['FASTLANE_ISSUER_ID'],
      key_filepath: "api_key.p8"
    )

    # Download/maak signing certificate (dist)
    cert(
      api_key: api_key,
      output_path: "/tmp/certs"
    )

    # Download/maak App Store provisioning profile
    sigh(
      api_key: api_key,
      app_identifier: "com.#{ENV['TEAMID']}.glucodash",
      output_path: "/tmp/profiles",
      provisioning_name: "GlucoDash AppStore",
      force: true
    )

    # Update project naar manual signing met het gedownloade profiel
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["TEAMID"],
      path: "ios/App/App.xcodeproj",
      profile_name: "GlucoDash AppStore",
      code_sign_identity: "iPhone Distribution"
    )

    update_app_identifier(
      xcodeproj: "ios/App/App.xcodeproj",
      plist_path: "App/Info.plist",
      app_identifier: "com.#{ENV['TEAMID']}.glucodash"
    )

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.#{ENV['TEAMID']}.glucodash" => "GlucoDash AppStore"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
