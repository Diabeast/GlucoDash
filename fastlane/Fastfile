default_platform(:ios)

APP_VERSION = "1.0"   # ← pas dit aan voor een nieuwe versie (bijv. "1.1" of "2.0")

platform :ios do
  desc "Build GlucoDash en upload naar TestFlight voor de interne groep Testers"
  lane :build_upload do

    # 1. API key voor App Store Connect
    api_key = app_store_connect_api_key(
      key_id: ENV['FASTLANE_KEY_ID'],
      issuer_id: ENV['FASTLANE_ISSUER_ID'],
      key_filepath: File.expand_path("../api_key.p8", __dir__)
    )

    # Lees de correcte bundle ID direct uit capacitor.config.json
    require 'json'
    cap_cfg          = JSON.parse(File.read(File.expand_path("../capacitor.config.json", __dir__)))
    app_bundle_id    = cap_cfg['appId']                    # bijv. "com.9CGZ7BWVXT.glucodash"
    widget_bundle_id = "#{app_bundle_id}.widget"           # bijv. "com.9CGZ7BWVXT.glucodash.widget"
    UI.message("App bundle ID (uit capacitor.config.json): #{app_bundle_id}")
    UI.message("Widget bundle ID: #{widget_bundle_id}")

    # 2. Activeer HealthKit capability op de App ID (direct voor match)
    require 'openssl'
    require 'base64'
    require 'net/http'

    begin
      key_path    = File.expand_path("../api_key.p8", __dir__)
      key_content = File.binread(key_path)
      pkey        = OpenSSL::PKey.read(key_content)
      kid         = ENV['FASTLANE_KEY_ID']
      iss         = ENV['FASTLANE_ISSUER_ID']
      now         = Time.now.to_i

      hdr = Base64.urlsafe_encode64(JSON.generate({alg:'ES256',kid:kid,typ:'JWT'}), padding: false)
      pld = Base64.urlsafe_encode64(JSON.generate({iss:iss,iat:now,exp:now+1200,aud:'appstoreconnect-v1'}), padding: false)
      si  = "#{hdr}.#{pld}"
      der = pkey.sign(OpenSSL::Digest::SHA256.new, si)
      asn = OpenSSL::ASN1.decode(der)
      r   = asn.value[0].value.to_s(2).rjust(32, "\x00").bytes.last(32).pack('C*')
      s   = asn.value[1].value.to_s(2).rjust(32, "\x00").bytes.last(32).pack('C*')
      jwt = "#{si}.#{Base64.urlsafe_encode64(r + s, padding: false)}"

      bid_str = app_bundle_id
      UI.message("Zoek App ID: #{bid_str}")

      # Zoek het Bundle ID resource ID op
      uri = URI("https://api.appstoreconnect.apple.com/v1/bundleIds?filter[identifier]=#{bid_str}")
      req = Net::HTTP::Get.new(uri)
      req['Authorization'] = "Bearer #{jwt}"
      res = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |h| h.request(req) }
      data = JSON.parse(res.body)
      bid  = data['data']&.first

      if bid
        UI.message("App ID gevonden: #{bid['id']}")

        hk_body = JSON.generate({
          data: {
            type: "bundleIdCapabilities",
            attributes: { capabilityType: "HEALTH_KIT", settings: [] },
            relationships: { bundleId: { data: { id: bid['id'], type: "bundleIds" } } }
          }
        })

        uri2 = URI("https://api.appstoreconnect.apple.com/v1/bundleIdCapabilities")
        req2 = Net::HTTP::Post.new(uri2)
        req2['Authorization'] = "Bearer #{jwt}"
        req2['Content-Type']  = 'application/json'
        req2.body = hk_body
        res2 = Net::HTTP.start(uri2.hostname, uri2.port, use_ssl: true) { |h| h.request(req2) }

        case res2.code.to_i
        when 201
          UI.success("HealthKit capability INGESCHAKELD op App ID!")
        when 409
          UI.success("HealthKit was al ingeschakeld op App ID.")
        else
          UI.important("HealthKit response #{res2.code}: #{res2.body[0..300]}")
        end

        # Wacht 8 seconden zodat Apple de wijziging kan propageren naar provisioning
        UI.message("Wacht 8s voor Apple propagatie...")
        sleep(8)
      else
        UI.important("App ID #{bid_str} niet gevonden! Response: #{res.code} #{res.body[0..200]}")
      end

      # ---- Widget Bundle ID registreren + WidgetKit capability inschakelen ----
      widget_bid_str = widget_bundle_id
      UI.message("Zoek/maak widget App ID: #{widget_bid_str}")

      uri_w = URI("https://api.appstoreconnect.apple.com/v1/bundleIds?filter[identifier]=#{widget_bid_str}")
      req_w = Net::HTTP::Get.new(uri_w)
      req_w['Authorization'] = "Bearer #{jwt}"
      res_w = Net::HTTP.start(uri_w.hostname, uri_w.port, use_ssl: true) { |h| h.request(req_w) }
      data_w = JSON.parse(res_w.body)
      widget_bid = data_w['data']&.first

      unless widget_bid
        UI.message("Widget App ID niet gevonden, aanmaken...")
        create_body = JSON.generate({
          data: {
            type: "bundleIds",
            attributes: {
              identifier: widget_bid_str,
              name: "GlucoDash Widget",
              platform: "IOS"
            }
          }
        })
        uri_c = URI("https://api.appstoreconnect.apple.com/v1/bundleIds")
        req_c = Net::HTTP::Post.new(uri_c)
        req_c['Authorization'] = "Bearer #{jwt}"
        req_c['Content-Type']  = 'application/json'
        req_c.body = create_body
        res_c = Net::HTTP.start(uri_c.hostname, uri_c.port, use_ssl: true) { |h| h.request(req_c) }
        if res_c.code.to_i == 201
          widget_bid = JSON.parse(res_c.body)['data']
          UI.success("Widget App ID aangemaakt: #{widget_bid['id']}")
        else
          UI.important("Widget App ID aanmaken mislukt #{res_c.code}: #{res_c.body[0..300]}")
        end
      else
        UI.message("Widget App ID gevonden: #{widget_bid['id']}")
      end

      if widget_bid
        wid = widget_bid['id']

        # WidgetKit capability inschakelen op widget bundle ID
        wk_body = JSON.generate({
          data: {
            type: "bundleIdCapabilities",
            attributes: { capabilityType: "WIDGET_KIT", settings: [] },
            relationships: { bundleId: { data: { id: wid, type: "bundleIds" } } }
          }
        })
        uri_wk = URI("https://api.appstoreconnect.apple.com/v1/bundleIdCapabilities")
        req_wk = Net::HTTP::Post.new(uri_wk)
        req_wk['Authorization'] = "Bearer #{jwt}"
        req_wk['Content-Type']  = 'application/json'
        req_wk.body = wk_body
        res_wk = Net::HTTP.start(uri_wk.hostname, uri_wk.port, use_ssl: true) { |h| h.request(req_wk) }
        case res_wk.code.to_i
        when 201 then UI.success("WidgetKit capability INGESCHAKELD op widget App ID!")
        when 409 then UI.success("WidgetKit was al ingeschakeld op widget App ID.")
        else          UI.important("WidgetKit response #{res_wk.code}: #{res_wk.body[0..300]}")
        end

        # ── Maak GlucoDash eigen App Group aan + koppel aan hoofd-app en widget ──
        gd_group_id  = "group.com.9CGZ7BWVXT.glucodash"
        gd_ag_res_id = nil

        # Stap 1: Probeer App Group te vinden via main app's gekoppelde groepen
        if bid
          uri_mag = URI("https://api.appstoreconnect.apple.com/v1/bundleIds/#{bid['id']}/appGroups")
          req_mag = Net::HTTP::Get.new(uri_mag)
          req_mag['Authorization'] = "Bearer #{jwt}"
          res_mag = Net::HTTP.start(uri_mag.hostname, uri_mag.port, use_ssl: true) { |h| h.request(req_mag) }
          main_ags = JSON.parse(res_mag.body)['data'] || []
          found = main_ags.find { |g| g.dig('attributes','identifier') == gd_group_id }
          gd_ag_res_id = found['id'] if found
          UI.message("GlucoDash App Group via main app: #{gd_ag_res_id || 'niet gevonden'}")
        end

        # Stap 2: Aanmaken als het nog niet bestaat
        if !gd_ag_res_id
          UI.message("GlucoDash App Group aanmaken: #{gd_group_id}")
          create_ag = JSON.generate({ data: { type: "appGroups", attributes: { identifier: gd_group_id, name: "GlucoDash" } } })
          uri_cag = URI("https://api.appstoreconnect.apple.com/v1/appGroups")
          req_cag = Net::HTTP::Post.new(uri_cag)
          req_cag['Authorization'] = "Bearer #{jwt}"
          req_cag['Content-Type']  = 'application/json'
          req_cag.body = create_ag
          res_cag = Net::HTTP.start(uri_cag.hostname, uri_cag.port, use_ssl: true) { |h| h.request(req_cag) }
          case res_cag.code.to_i
          when 201
            gd_ag_res_id = JSON.parse(res_cag.body)['data']['id']
            UI.success("✅ GlucoDash App Group aangemaakt: #{gd_ag_res_id}")
          when 409
            # Al aangemaakt — haal ID op via globale lijst
            URI_all = URI("https://api.appstoreconnect.apple.com/v1/appGroups?limit=200")
            req_all = Net::HTTP::Get.new(URI_all)
            req_all['Authorization'] = "Bearer #{jwt}"
            res_all = Net::HTTP.start(URI_all.hostname, URI_all.port, use_ssl: true) { |h| h.request(req_all) }
            all_ags = JSON.parse(res_all.body)['data'] || []
            found = all_ags.find { |g| g.dig('attributes','identifier') == gd_group_id }
            gd_ag_res_id = found['id'] if found
            UI.success("✅ GlucoDash App Group al bestaand: #{gd_ag_res_id}")
          else
            UI.important("App Group aanmaken mislukt #{res_cag.code}: #{res_cag.body[0..300]}")
          end
        end

        if gd_ag_res_id
          # Stap 3: Schakel APP_GROUPS capability in op beide bundle IDs
          [bid&.dig('id'), wid].compact.each do |b_id|
            cap_body = JSON.generate({ data: { type: "bundleIdCapabilities",
              attributes: { capabilityType: "APP_GROUPS", settings: [] },
              relationships: { bundleId: { data: { id: b_id, type: "bundleIds" } } } } })
            uri_cap = URI("https://api.appstoreconnect.apple.com/v1/bundleIdCapabilities")
            req_cap = Net::HTTP::Post.new(uri_cap)
            req_cap['Authorization'] = "Bearer #{jwt}"
            req_cap['Content-Type']  = 'application/json'
            req_cap.body = cap_body
            res_cap = Net::HTTP.start(uri_cap.hostname, uri_cap.port, use_ssl: true) { |h| h.request(req_cap) }
            UI.message("APP_GROUPS capability voor #{b_id}: #{res_cap.code}")
          end

          # Stap 4: Koppel App Group aan hoofd-app en widget
          assoc = JSON.generate({ data: [{ type: "appGroups", id: gd_ag_res_id }] })
          [bid&.dig('id'), wid].compact.each do |b_id|
            uri_a = URI("https://api.appstoreconnect.apple.com/v1/bundleIds/#{b_id}/relationships/appGroups")
            req_a = Net::HTTP::Post.new(uri_a)
            req_a['Authorization'] = "Bearer #{jwt}"
            req_a['Content-Type']  = 'application/json'
            req_a.body = assoc
            res_a = Net::HTTP.start(uri_a.hostname, uri_a.port, use_ssl: true) { |h| h.request(req_a) }
            case res_a.code.to_i
            when 204 then UI.success("✅ App Group gekoppeld aan #{b_id}")
            when 409 then UI.success("✅ App Group al gekoppeld aan #{b_id}")
            else          UI.important("Koppelen #{b_id} #{res_a.code}: #{res_a.body[0..200]}")
            end
          end

          UI.message("Wacht 10s voor Apple App Group propagatie...")
          sleep(10)
        else
          UI.error("GlucoDash App Group ID niet beschikbaar — widget krijgt geen live data")
        end

        # Schrijf widget entitlements met onze eigen App Group (__dir__ = fastlane/)
        widget_ent = File.expand_path("../ios/App/GlucoDashWidget/GlucoDashWidget.entitlements", __dir__)
        UI.message("Widget entitlements: #{widget_ent} (bestaat: #{File.exist?(widget_ent)})")
        if gd_ag_res_id
          File.write(widget_ent, "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\">\n<plist version=\"1.0\">\n<dict>\n  <key>com.apple.security.application-groups</key>\n  <array>\n    <string>#{gd_group_id}</string>\n  </array>\n</dict>\n</plist>\n")
          UI.success("Widget entitlements gezet met #{gd_group_id}")
        else
          File.write(widget_ent, "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\">\n<plist version=\"1.0\">\n<dict/>\n</plist>\n")
          UI.important("Widget entitlements leeg (App Group niet beschikbaar)")
        end
      end

    rescue => e
      UI.important("HealthKit/Widget enable fout: #{e.message}\n#{e.backtrace.first(3).join("\n")}")
    end

    keychain_name = "build.keychain"
    keychain_path = File.expand_path("~/Library/Keychains/build.keychain-db")
    keychain_pass = "buildpass"

    # 3. Maak tijdelijke keychain aan voor CI (GitHub Actions)
    create_keychain(
      name: keychain_name,
      password: keychain_pass,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    # 4. Match: haal certificaten en provisioning profiles op
    #    force: true → genereert altijd een NIEUW profiel (pikt HealthKit op)
    match(
      type: "appstore",
      api_key: api_key,
      app_identifier: [app_bundle_id, widget_bundle_id],
      keychain_name: keychain_name,
      keychain_password: keychain_pass,
      readonly: false,
      force: true
    )

    # 5. Controleer of HealthKit in het provisioning profile zit
    profile_path = ENV["sigh_#{app_bundle_id}_appstore_profile-path"] ||
                   Dir.glob(File.expand_path("~/Library/MobileDevice/Provisioning Profiles/*.mobileprovision")).
                     select { |f| File.mtime(f) > Time.now - 120 }.first

    if profile_path && File.exist?(profile_path.to_s)
      plist_xml = `security cms -D -i "#{profile_path}" 2>/dev/null`
      if plist_xml.include?('healthkit')
        UI.success("✅ Provisioning profile bevat HealthKit!")
      else
        UI.error("❌ Provisioning profile MIST HealthKit!")
        UI.message("Profile entitlements sectie: #{plist_xml.scan(/Entitlements.*?<\/dict>/m).first.to_s[0..500]}")
      end
    else
      UI.important("Kon provisioning profile niet vinden voor verificatie.")
    end

    # 6. Keychain permissies goedzetten voor codesign
    sh("security set-key-partition-list -S apple-tool:,apple: -s -k '#{keychain_pass}' '#{keychain_path}' 2>/dev/null || true")

    update_app_identifier(
      xcodeproj: "ios/App/App.xcodeproj",
      plist_path: "App/Info.plist",
      app_identifier: app_bundle_id
    )

    profile_name = ENV["sigh_#{app_bundle_id}_appstore_profile-name"] || "match AppStore #{app_bundle_id}"

    # 7. Code signing instellingen bijwerken
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["TEAMID"],
      path: "ios/App/App.xcodeproj",
      profile_name: profile_name,
      code_sign_identity: "iPhone Distribution"
    )

    widget_profile_name = ENV["sigh_#{widget_bundle_id}_appstore_profile-name"] ||
                          "match AppStore #{widget_bundle_id}"

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["TEAMID"],
      path: "ios/App/App.xcodeproj",
      targets: ["GlucoDashWidget"],
      profile_name: widget_profile_name,
      code_sign_identity: "iPhone Distribution"
    )

    # 8. Versie en build number instellen
    increment_version_number(
      version_number: APP_VERSION,
      xcodeproj: "ios/App/App.xcodeproj"
    )
    build_number = ENV['GITHUB_RUN_NUMBER'] || Time.now.to_i.to_s
    increment_build_number(
      build_number: build_number,
      xcodeproj: "ios/App/App.xcodeproj"
    )

    # 9. De .ipa file builden
    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          app_bundle_id    => profile_name,
          widget_bundle_id => widget_profile_name
        }
      }
    )

    # 10. Uploaden naar TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: false,
      changelog: "Nieuwe build via CI",
      beta_app_description: "GlucoDash - glucose en insuline dashboard",
      beta_app_feedback_email: "arthurmink@gmail.com"
    )

  end
end
